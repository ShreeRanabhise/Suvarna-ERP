generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  SUPER_ADMIN
  OWNER
  STAFF
}

enum Plan {
  STANDARD
  ENTERPRISE
}

enum LoanStatus {
  ACTIVE
  CLOSED
  OVERDUE
  AUCTION
  RENEWED
}

enum PaymentMode {
  CASH
  UPI
  BANK
  CHEQUE
}

enum PaymentStatus {
  COMPLETED
  REVERSED
}

model User {
  id        String   @id @default(uuid())
  authId    String?  @unique
  email     String   @unique
  name      String
  role      Role     @default(OWNER)
  shopId    String?  
  branchId  String?  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  shop      Shop?    @relation(fields: [shopId], references: [id])
  branch    Branch?  @relation(fields: [branchId], references: [id])
  auditLogs AuditLog[]

  @@index([shopId])
  @@index([branchId])
}

model Shop {
  id               String       @id @default(uuid())
  name             String
  subscriptionPlan Plan         @default(STANDARD)
  subscriptionEnd  DateTime
  whatsappAddon    Boolean      @default(false)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  
  users            User[]
  branches         Branch[]
  customers        Customer[]
  loans            Loan[]
  auditLogs        AuditLog[]
  notificationLogs NotificationLog[]
}

model Branch {
  id        String   @id @default(uuid())
  name      String
  shopId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  users     User[]
  customers Customer[]
  loans     Loan[]

  @@index([shopId])
}

model Customer {
  id          String   @id @default(uuid())
  shopId      String
  branchId    String?
  firstName   String   // Will store full Name
  lastName    String   @default("")
  phone       String   // Mobile
  email       String?  // Optional email
  aadhaar     String   // Required Aadhaar
  pan         String?
  address          String   // Required Address
  aadhaarPhotoUrl  String?
  customerPhotoUrl String?
  isDeleted   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  shop        Shop     @relation(fields: [shopId], references: [id], onDelete: Restrict)
  branch      Branch?  @relation(fields: [branchId], references: [id])
  loans       Loan[]
  kycVersions CustomerKYCVersion[]

  @@index([shopId])
  @@index([branchId])
  @@unique([shopId, aadhaar])
  @@unique([shopId, phone])
}

model Loan {
  id             String     @id @default(uuid())
  loanNumber     String     @unique // e.g. SGL-2024-0001
  shopId         String
  branchId       String?
  customerId     String
  principalAmount Decimal    @db.Decimal(12, 2)
  interestRate   Decimal    @db.Decimal(5, 2)      // Monthly interest rate percentage
  ltvPercentage  Decimal    @db.Decimal(5, 2)
  status         LoanStatus @default(ACTIVE)
  startDate      DateTime   @default(now())
  endDate        DateTime?  // Expected or actual closure date
  isDeleted      Boolean    @default(false)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  version        Int        @default(0) // Optimistic locking version tag

  shop           Shop          @relation(fields: [shopId], references: [id], onDelete: Restrict)
  branch         Branch?       @relation(fields: [branchId], references: [id])
  customer       Customer      @relation(fields: [customerId], references: [id], onDelete: Restrict)
  pledgedItems   PledgedItem[]
  payments       Payment[]
  ledgerEntries  LedgerEntry[]
  stateHistory   LoanStateHistory[]

  @@index([shopId])
  @@index([branchId])
  @@index([customerId])
}

model PledgedItem {
  id          String   @id @default(uuid())
  loanId      String
  name        String   // e.g. Gold Chain
  weightGrams Decimal  @db.Decimal(10, 3)
  purity      String   // e.g. 22K
  valuation   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  loan        Loan     @relation(fields: [loanId], references: [id], onDelete: Restrict)

  @@index([loanId])
}

model Payment {
  id            String      @id @default(uuid())
  loanId        String
  amountPaid    Decimal     @db.Decimal(12, 2)
  principalPaid Decimal     @db.Decimal(12, 2) @default(0)
  interestPaid  Decimal     @db.Decimal(12, 2) @default(0)
  paymentDate   DateTime    @default(now())
  paymentMode   PaymentMode @default(CASH)
  referenceId   String?     // For UPI/Bank transfers
  idempotencyKey String?    @unique
  status        PaymentStatus @default(COMPLETED)
  reversedById  String?
  reversedAt    DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  loan          Loan        @relation(fields: [loanId], references: [id], onDelete: Restrict)

  @@index([loanId])
}

model NotificationLog {
  id        String   @id @default(uuid())
  shopId    String
  type      String   // e.g. WHATSAPP, SMS
  recipient String   // Phone number
  message   String
  status    String   // SENT, FAILED
  createdAt DateTime @default(now())

  shop      Shop     @relation(fields: [shopId], references: [id], onDelete: Cascade)

  @@index([shopId])
}

model AuditLog {
  id        String   @id @default(uuid())
  shopId    String?  // Null for Super Admin actions
  userId    String
  action    String   // e.g. CREATE_LOAN, DELETE_CUSTOMER
  entity    String   // e.g. LOAN, CUSTOMER
  entityId  String
  details   Json?    // JSON object details
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([shopId])
  @@index([userId])
}

enum LedgerCategory {
  PRINCIPAL
  INTEREST
  PENALTY
  FEES
}

enum LedgerType {
  DEBIT
  CREDIT
}

model LedgerEntry {
  id             String         @id @default(uuid())
  shopId         String
  branchId       String?
  loanId         String
  paymentId      String?
  category       LedgerCategory
  type           LedgerType
  amount         Decimal        @db.Decimal(12, 2)
  balanceAfter   Decimal        @db.Decimal(12, 2)
  performedBy    String         // User ID
  idempotencyKey String?        @unique
  isReversal     Boolean        @default(false)
  createdAt      DateTime       @default(now())

  loan           Loan           @relation(fields: [loanId], references: [id], onDelete: Restrict)

  @@index([loanId])
  @@index([shopId])
}

model CustomerKYCVersion {
  id          String   @id @default(uuid())
  customerId  String
  version     Int
  firstName   String
  lastName    String
  phone       String
  email       String?
  aadhaar     String
  address     String
  changedById String
  changedAt   DateTime @default(now())
  reason      String?

  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
}

model LoanStateHistory {
  id          String     @id @default(uuid())
  loanId      String
  fromStatus  LoanStatus
  toStatus    LoanStatus
  changedById String
  changedAt   DateTime   @default(now())
  details     String?    // JSON context

  loan        Loan       @relation(fields: [loanId], references: [id], onDelete: Cascade)

  @@index([loanId])
}

model IdempotencyLog {
  id        String   @id @default(uuid())
  key       String   @unique
  shopId    String
  userId    String
  action    String
  payload   String?
  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([key])
}

model RateLimit {
  id        String   @id @default(uuid())
  key       String   @unique
  count     Int      @default(0)
  expiresAt DateTime

  @@index([key])
}
